index 4f37cbb..897677e 100644
--- a/src/game/player/client.c
+++ b/src/game/player/client.c
@@ -27,6 +27,158 @@
 #include "../header/local.h"
 #include "../monster/misc/player.h"
 
+#ifdef __EMSCRIPTEN__
+#define Q2_WEARABLE_ENEMY_RANGE 900.0f
+#define Q2_WEARABLE_SIDE_DOT 0.25f
+#define Q2_WEARABLE_CENTER_DOT 0.70f
+
+extern int Q2_ConsumeEnemyTurn(void);
+extern void Q2_SetEnemyIndicators(int left, int right);
+extern void Q2_SetViewYaw(float yaw);
+
+static qboolean
+Q2_WearableEnemyTarget(edict_t *candidate)
+{
+	if (!candidate || !candidate->inuse || !candidate->takedamage)
+	{
+		return false;
+	}
+
+	if (!(candidate->svflags & SVF_MONSTER))
+	{
+		return false;
+	}
+
+	if (candidate->deadflag == DEAD_DEAD)
+	{
+		return false;
+	}
+
+	if (candidate->monsterinfo.aiflags & AI_GOOD_GUY)
+	{
+		return false;
+	}
+
+	return true;
+}
+
+static qboolean
+Q2_WearableShouldAutoFire(edict_t *ent)
+{
+	vec3_t forward, start, end;
+	trace_t tr;
+
+	if (!ent || !ent->client || ent->deadflag)
+	{
+		return false;
+	}
+
+	AngleVectors(ent->client->v_angle, forward, NULL, NULL);
+	VectorCopy(ent->s.origin, start);
+	start[2] += ent->viewheight;
+	VectorMA(start, 1000, forward, end);
+
+	tr = gi.trace(start, NULL, NULL, end, ent, MASK_SHOT);
+	return Q2_WearableEnemyTarget(tr.ent);
+}
+
+static edict_t *
+Q2_WearableFindSideEnemy(edict_t *ent, int direction, float *yaw_out)
+{
+	vec3_t forward, right, offset, angles;
+	edict_t *best;
+	float best_dist;
+	int i;
+
+	if (!ent || !ent->client || ent->deadflag)
+	{
+		return NULL;
+	}
+
+	best = NULL;
+	best_dist = Q2_WEARABLE_ENEMY_RANGE + 1.0f;
+
+	AngleVectors(ent->client->v_angle, forward, right, NULL);
+
+	for (i = 1; i < globals.num_edicts; i++)
+	{
+		edict_t *candidate = &g_edicts[i];
+		float dist, side, center;
+
+		if (!Q2_WearableEnemyTarget(candidate))
+		{
+			continue;
+		}
+
+		VectorSubtract(candidate->s.origin, ent->s.origin, offset);
+		offset[2] = 0;
+		dist = VectorNormalize(offset);
+
+		if ((dist <= 1.0f) || (dist > Q2_WEARABLE_ENEMY_RANGE))
+		{
+			continue;
+		}
+
+		side = DotProduct(offset, right);
+		center = DotProduct(offset, forward);
+
+		if (((direction < 0) && (side > -Q2_WEARABLE_SIDE_DOT)) ||
+			((direction > 0) && (side < Q2_WEARABLE_SIDE_DOT)))
+		{
+			continue;
+		}
+
+		if (center > Q2_WEARABLE_CENTER_DOT)
+		{
+			continue;
+		}
+
+		if (dist < best_dist)
+		{
+			best = candidate;
+			best_dist = dist;
+
+			if (yaw_out)
+			{
+				vectoangles(offset, angles);
+				*yaw_out = angles[YAW];
+			}
+		}
+	}
+
+	return best;
+}
+
+static void
+Q2_WearableUpdateEnemyAssist(edict_t *ent, usercmd_t *ucmd)
+{
+	int turn;
+	float yaw;
+	qboolean left, right;
+
+	if (!ent || !ent->client || ent->deadflag)
+	{
+		Q2_SetEnemyIndicators(false, false);
+		return;
+	}
+
+	left = Q2_WearableFindSideEnemy(ent, -1, NULL) != NULL;
+	right = Q2_WearableFindSideEnemy(ent, 1, NULL) != NULL;
+	Q2_SetEnemyIndicators(left, right);
+
+	turn = Q2_ConsumeEnemyTurn();
+	yaw = 0.0f;
+
+	if (((turn < 0) && Q2_WearableFindSideEnemy(ent, -1, &yaw)) ||
+		((turn > 0) && Q2_WearableFindSideEnemy(ent, 1, &yaw)))
+	{
+		ent->client->v_angle[YAW] = yaw;
+		ucmd->angles[YAW] = ANGLE2SHORT(yaw);
+		Q2_SetViewYaw(yaw);
+	}
+}
+#endif
