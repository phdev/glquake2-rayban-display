+static int q2_wearable_enemy_indicators;
+static int q2_wearable_enemy_turn_request;
+
+static float
+Q2_Normalize360(float angle)
+{
+	while (angle >= 360.0f)
+	{
+		angle -= 360.0f;
+	}
+
+	while (angle < 0.0f)
+	{
+		angle += 360.0f;
+	}
+
+	return angle;
+}
+
+EMSCRIPTEN_KEEPALIVE
+void
+Q2_AddViewAngles(float dyaw, float dpitch)
+{
+	cl.viewangles[YAW] = Q2_Normalize360(cl.viewangles[YAW] + dyaw);
+	cl.viewangles[PITCH] += dpitch;
+
+	if (cl.viewangles[PITCH] > 89.0f)
+	{
+		cl.viewangles[PITCH] = 89.0f;
+	}
+
+	if (cl.viewangles[PITCH] < -89.0f)
+	{
+		cl.viewangles[PITCH] = -89.0f;
+	}
+}
+
+EMSCRIPTEN_KEEPALIVE
+void
+Q2_SetViewYaw(float yaw)
+{
+	cl.viewangles[YAW] = Q2_Normalize360(yaw);
+}
+
+EMSCRIPTEN_KEEPALIVE
+int
+Q2_GetEnemyIndicators(void)
+{
+	return q2_wearable_enemy_indicators;
+}
+
+EMSCRIPTEN_KEEPALIVE
+void
+Q2_RequestEnemyTurn(int direction)
+{
+	if (direction < 0)
+	{
+		q2_wearable_enemy_turn_request = -1;
+	}
+	else if (direction > 0)
+	{
+		q2_wearable_enemy_turn_request = 1;
+	}
+	else
+	{
+		q2_wearable_enemy_turn_request = 0;
+	}
+}
+
+EMSCRIPTEN_KEEPALIVE
+void
+Q2_SetEnemyIndicators(int left, int right)
+{
+	q2_wearable_enemy_indicators = (left ? 1 : 0) | (right ? 2 : 0);
+}
+
+EMSCRIPTEN_KEEPALIVE
+int
+Q2_ConsumeEnemyTurn(void)
+{
+	const int direction = q2_wearable_enemy_turn_request;
+	q2_wearable_enemy_turn_request = 0;
+	return direction;
+}
+
+EMSCRIPTEN_KEEPALIVE
+void
+Q2_SetWearableAction(int action, int down)
+{
+	if ((action < 0) || (action >= Q2_WEARABLE_ACTION_COUNT))
+	{
+		return;
+	}
+
+	q2_wearable_actions[action] = down ? true : false;
+}
+
+static void
+Q2_ApplyWearableActions(usercmd_t *cmd)
+{
+	if (!cmd)
+	{
+		return;
+	}
+
+	if (q2_wearable_actions[Q2_WEARABLE_FORWARD] && (cmd->forwardmove < 120))
+	{
+		cmd->forwardmove = 120;
+	}
+
+	if (q2_wearable_actions[Q2_WEARABLE_JUMP] && (cmd->upmove < 200))
+	{
+		cmd->upmove = 200;
+	}
+
+	if (q2_wearable_actions[Q2_WEARABLE_CROUCH] && (cmd->upmove > -200))
+	{
+		cmd->upmove = -200;
+	}
+
+	if (q2_wearable_actions[Q2_WEARABLE_ATTACK])
+	{
+		cmd->buttons |= BUTTON_ATTACK;
+	}
+
+	if (q2_wearable_actions[Q2_WEARABLE_USE])
+	{
+		cmd->buttons |= BUTTON_USE;
+	}
+}
+#endif
